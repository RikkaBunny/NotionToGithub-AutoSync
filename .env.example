# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real secrets.

# Notion integration token (required)
# Get one at https://www.notion.so/my-integrations
NOTION_SECRET=

# Target database ID (required)
# Copy from the database URL; hyphens are optional.
NOTION_DATABASE=

# --- Optional tuning ---

# Comma-separated status values to sync (default: Done)
# FILTER_STATUS=Done,Published

# Output directories (defaults: articles, assets)
# ARTICLE_DIR=articles
# ASSETS_DIR=assets

# Skip pages whose last_edited_time is unchanged (default: true)
# INCREMENTAL=true

# Per-image download timeout in ms (default: 30000)
# FETCH_TIMEOUT_MS=30000

# Retry count for Notion API and image downloads (default: 3)
# MAX_RETRIES=3

# Delete orphan assets that are no longer referenced (default: true)
# PRUNE_ASSETS=true
